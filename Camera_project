import cv2
import numpy as np

#Setting a variable to remember if we found our target object
remembered_object_location = None

def take_and_save_picture():
    #Step 1: Connect to the camera, show a live feed,
    #and save a picture when the user presses 's'.

    print("Connecting to camera... Press 's' to take a snapshot, or 'q' to quit.")
    #Initialize the camera
    camera = cv2.capacities = cv2.VideoCapture(0)

    if not camera.isOpened():
        print("Error: Could not connect to the camera.")
        return None
    
    captured_image = None

    while True:
        #Read a frame from the live camera feed
        ret, frame = camera.read()
        if not ret:
            print("Failed to grab frame.")
            break
    
        #Display the live feed in a window
        cv2.imshow("Live Camera Feed - Press 's' to Save Picture", frame)

        #Wait for user to press key
        key = cv2.waitKey(1) & 0xFF

        if key == ord('s'):
            #Save the current frame as an image file
            filename = "race_course_object.jpg"
            cv2.imwrite(filename, frame)
            print(f"Picture successfully saved as '{filename}'!")
            captured_image = frame
            break
        elif key == ord('q'):
            print("Exiting without saving.")
            break
        
    #Release the camera hardware and close the window
    camera.release()
    cv2.destroyAllWindows()
    return captured_image


def detect_red_ring(image):
    #Step 2: Process the image to detect a red ring/object

    if image is None:
        print("No image provided for processing.")
        return None

    #Convert the image from BGR(standard open cv format) to HSV (Hue, Saturation, Value)
    #HSV makes it much easier to isolate specific colors like red
    hsv_image = cv2.cvtColor(image, cv2.COLOR_BGR2HSV)

    #In HSV, red exists in 2 ranges so we have to define both
    lower_red1 = np.array([0, 120, 70])
    upper_red1 = np.array([10, 255, 255])
    lower_red2 = np.array([170, 120, 70])
    upper_red2 = np.array([180, 255, 255])

    #Create masks to isolate the red pixels
    mask1 = cv2. inRange(hsv_image, lower_red1, upper_red1)
    mask2 = cv2. inRange(hsv_image, lower_red2, upper_red2)
    red_mask = mask1 + mask2 #Combine both red masks

    #Find contours(the outlines of the shapes detected in the mask)
    contours, _ = cv2.findContours(red_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

    detected_center = None

    # If we found at least one contour, let's look at the largest one
    if contours:
        # Sort contours by area to find the biggest red object
        largest_contour = max(contours, key=cv2.contourArea)
        
        # Only consider it a valid object if it's big enough (filters out small background noise)
        if cv2.contourArea(largest_contour) > 500:
            # Get a bounding rectangle around the detected red shape
            x, y, w, h = cv2.boundingRect(largest_contour)
            
            # Calculate the center coordinate of the object
            center_x = x + (w // 2)
            center_y = y + (h // 2)
            detected_center = (center_x, center_y)

            # Draw a green rectangle around the red object on the original image
            cv2.rectangle(image, (x, y), (x + w, y + h), (0, 255, 0), 3)
            # Draw a small dot at the center
            cv2.circle(image, detected_center, 5, (255, 0, 0), -1)
            
            print(f"Red object detected! Center coordinates: {detected_center}")
        else:
            print("Red color found, but it's too small to be our target.")
    else:
        print("No red objects detected.")

    # Show the final processed result
    cv2.imshow("Processed Detection Image", image)
    cv2.waitKey(0)  # Wait for any key press to close the window
    cv2.destroyAllWindows()

    return detected_center


def remember_and_act():
    #Step 3: Call upon the memory of the program to decide what action to take.
    
    print("\n--- Robot Decision Module Activated ---")
    global remembered_object_location

    if remembered_object_location is not None:
        print(f"Memory Status: Target spotted earlier at {remembered_object_location}.")
        print("Decision: Target found! Ready the gripper mechanisms to pick up the red ring.")
    else:
        print("Memory Status: No target object was recorded.")
        print("Decision: Continue driving along the race course and scanning.")


# --- MAIN EXECUTION FLOW ---
if __name__ == "__main__":
    print("=== STARTING RACE COURSE OBJECT DETECTION PROGRAM ===")
    
    # 1. Take snapshot
    img = take_and_save_picture()
    
    # 2. Process image and look for the pattern (red ring)
    if img is not None:
        # Save the result to our global "memory" variable
        remembered_object_location = detect_red_ring(img)
    
    # 3. Recall the memory later in the program
    remember_and_act()
    
    print("\n=== PROGRAM TERMINATED ===")







